doctype html
html
  head
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    meta(http-equiv='Content-Type', content='text/html; charset=UTF-8')
    title #{subject}
    style.
      /* Base Resets */
      body {
        margin: 0;
        padding: 0;
        font-family: sans-serif;
        background-color: #f6f6f6;
        -webkit-font-smoothing: antialiased;
        font-size: 14px;
        line-height: 1.4;
      }
      .container {
        display: block;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .main {
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
        border: 1px solid #f0f0f0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
      }
      .header {
        background: #3b1f6e;
        padding: 24px 32px;
        text-align: center;
      }
      .header h1 {
        color: #f59c1a;
        margin: 0;
        font-size: 28px;
        letter-spacing: 1px;
      }
      .wrapper {
        box-sizing: border-box;
        padding: 32px;
      }
      .footer {
        padding: 16px 32px;
        background: #fafafa;
        border-top: 1px solid #f0f0f0;
        text-align: center;
        font-size: 11px;
        color: #aaa;
      }
      .footer a {
        color: #3b1f6e;
        text-decoration: underline;
      }
      h2 {
        color: #3b1f6e;
        margin-top: 0;
        font-size: 24px;
      }
      p {
        font-size: 16px;
        line-height: 1.6;
        color: #555;
      }
      .btn {
        background: #f59c1a;
        color: #ffffff;
        text-decoration: none;
        padding: 14px 28px;
        border-radius: 24px;
        font-weight: bold;
        font-size: 16px;
        display: inline-block;
        box-shadow: 0 4px 6px rgba(245, 156, 26, 0.3);
      }
  body
    table.body(role='presentation', border='0', cellpadding='0', cellspacing='0', style='width: 100%; background-color: #f6f6f6;')
      tr
        td &nbsp;
        td.container
          .main
            .header
              h1 AasanBuy
            
            .wrapper
              block content
            
            .footer
              p © #{new Date().getFullYear()} AasanBuy. All rights reserved.
              p Need help? 
                a(href='mailto:support@aasanbuy.com') Contact Support
        td &nbsp;
